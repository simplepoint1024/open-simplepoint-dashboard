{
  "name": "simplepoint-react",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "scripts": {
    "dev:host": "pnpm --filter @simplepoint/host dev",
    "build:host": "pnpm --filter @simplepoint/host build",
    "dev:common": "pnpm --filter @simplepoint/common dev",
    "build:common": "pnpm --filter @simplepoint/common build",
    "dev:audit": "pnpm --filter @simplepoint/audit dev",
    "build:audit": "pnpm --filter @simplepoint/audit build",
    "dev:dna": "pnpm --filter @simplepoint/dna dev",
    "build:dna": "pnpm --filter @simplepoint/dna build",
    "dev:ai": "pnpm --filter @simplepoint/ai dev",
    "build:ai": "pnpm --filter @simplepoint/ai build",
    "typecheck:host": "tsc -p modules/simplepoint-host/tsconfig.json --noEmit",
    "typecheck:common": "tsc -p modules/simplepoint-common/tsconfig.json --noEmit",
    "typecheck:audit": "tsc -p modules/simplepoint-audit/tsconfig.json --noEmit",
    "typecheck:dna": "tsc -p modules/simplepoint-dna/tsconfig.json --noEmit",
    "typecheck:ai": "tsc -p modules/simplepoint-ai/tsconfig.json --noEmit",
    "typecheck:mocks": "tsc -p modules/mocks/tsconfig.json --noEmit",
    "typecheck": "pnpm run typecheck:common && pnpm run typecheck:audit && pnpm run typecheck:dna && pnpm run typecheck:ai && pnpm run typecheck:host && pnpm run typecheck:mocks",
    "i18n:sync": "node scripts/sync-i18n-bundles.mjs",
    "i18n:check": "node scripts/sync-i18n-bundles.mjs --check",
    "build": "pnpm --filter './modules/*' --if-present run build"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/view": "^6.43.6",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@rjsf/antd": "^6.7.0",
    "@rjsf/core": "^6.7.0",
    "@rjsf/utils": "^6.7.0",
    "@rjsf/validator-ajv8": "^6.7.0",
    "@tanstack/react-query": "^5.101.2",
    "@uiw/react-codemirror": "^4.25.11",
    "antd": "^6.5.1",
    "dayjs": "^1.11.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-highlight-words": "^0.21.0",
    "react-resizable": "^4.0.2",
    "react-router": "^8.2.0"
  },
  "devDependencies": {
    "@module-federation/rsbuild-plugin": "^2.8.0",
    "@rsbuild/core": "^2.1.6",
    "@rsbuild/plugin-react": "^2.1.0",
    "@rslib/core": "^0.23.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-highlight-words": "^0.20.1",
    "msw": "^2.15.0",
    "typescript": "^7.0.2"
  },
  "msw": {
    "workerDirectory": [
      "modules/simplepoint-host/public"
    ]
  }
}
